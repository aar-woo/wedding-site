# Copy to .env.local (gitignored) and fill in real values.
# NEVER prefix these with VITE_ — they are server-only secrets (see docs/identity-token-contract.md §5).
GUEST_TOKEN_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Optional. The deployed site origin used to build links. If unset, generate-links.js emits a clearly-marked placeholder host.
SITE_BASE_URL=https://your-domain.example

# Gmail SMTP credentials for send-invites.js (server-only — NEVER prefix with VITE_).
# GMAIL_APP_PASSWORD is a 16-char Google App Password, NOT your normal password.
GMAIL_USER=rinaaron5@gmail.com
GMAIL_APP_PASSWORD=replace-with-16-char-app-password
